# Git LFS tracking rules.
#
# Any file matching these patterns will be stored in Git Large File Storage
# instead of as a regular git blob, so the repo stays small and contributors
# don't get GitHub's "file is over 50 MB" warning.
#
# Contributors: install Git LFS once (`git lfs install`) before cloning or
# pushing, otherwise these files won't be uploaded/downloaded correctly.
# See the "Git LFS" section in README.md for the full setup.

# All HUC8 watershed boundaries (~57 MB) — bundled as a static resource.
tethysapp/fimserve_viewer/resources/all_huc8.geojson filter=lfs diff=lfs merge=lfs -text

# Catch-all for any future large geospatial assets dropped into resources/.
tethysapp/fimserve_viewer/resources/*.geojson filter=lfs diff=lfs merge=lfs -text
tethysapp/fimserve_viewer/resources/*.gpkg     filter=lfs diff=lfs merge=lfs -text
tethysapp/fimserve_viewer/resources/*.tif      filter=lfs diff=lfs merge=lfs -text
tethysapp/fimserve_viewer/resources/*.tiff     filter=lfs diff=lfs merge=lfs -text
